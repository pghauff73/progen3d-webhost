<?php
require __DIR__ . '/../includes/bootstrap.php';
header('Content-Type: application/json; charset=UTF-8');

$action = (string) ($_GET['action'] ?? '');

function json_body(): array
{
    $raw = file_get_contents('php://input');
    if (!$raw) {
        return [];
    }
    $data = json_decode($raw, true);
    return is_array($data) ? $data : [];
}

function json_response(array $data, int $status = 200): void
{
    http_response_code($status);
    echo json_encode($data, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
    exit;
}

if ($action === 'get_public') {
    $id = (int) ($_GET['id'] ?? 0);
    $file = find_public_file($id);
    if (!$file) {
        json_response(['ok' => false, 'error' => 'Published file not found.'], 404);
    }
    json_response(['ok' => true, 'file' => $file]);
}

if ($action === 'get') {
    require_login();
    $user = current_user();
    $id = (int) ($_GET['id'] ?? 0);
    $file = find_user_file($id, (int) $user['id']);
    if (!$file) {
        json_response(['ok' => false, 'error' => 'File not found.'], 404);
    }
    json_response(['ok' => true, 'file' => $file]);
}

require_login();
verify_csrf();
$user = current_user();
$body = json_body();

if ($action === 'save') {
    $id = isset($body['file_id']) && $body['file_id'] !== null ? (int) $body['file_id'] : (isset($body['id']) && $body['id'] !== null ? (int) $body['id'] : null);
    $title = (string) ($body['title'] ?? 'Untitled grammar');
    $content = (string) ($body['content'] ?? '');
    if ($content === '') {
        json_response(['ok' => false, 'error' => 'Grammar content is empty.'], 422);
    }
    $file = upsert_file_record((int) $user['id'], $id, $title, $content, false);
    json_response(['ok' => true, 'file' => ['id' => $file['id'], 'title' => $file['title']]]);
}

if ($action === 'publish') {
    $id = isset($body['file_id']) && $body['file_id'] !== null ? (int) $body['file_id'] : (isset($body['id']) && $body['id'] !== null ? (int) $body['id'] : null);
    $title = (string) ($body['title'] ?? 'Untitled grammar');
    $content = (string) ($body['content'] ?? '');
    if ($content === '') {
        json_response(['ok' => false, 'error' => 'Grammar content is empty.'], 422);
    }
    $file = upsert_file_record((int) $user['id'], $id, $title, $content, true);
    json_response(['ok' => true, 'file' => ['id' => $file['id'], 'title' => $file['title'], 'is_published' => 1]]);
}

if ($action === 'unpublish') {
    $id = (int) ($body['file_id'] ?? ($body['id'] ?? 0));
    if (!set_file_published($id, (int) $user['id'], false)) {
        json_response(['ok' => false, 'error' => 'File not found or not editable.'], 404);
    }
    json_response(['ok' => true]);
}

json_response(['ok' => false, 'error' => 'Unknown action.'], 400);
