function iw_json_body(): array
{
    $raw = file_get_contents('php://input');
    if (!$raw) {
        return [];
    }
    $data = json_decode($raw, true);
    return is_array($data) ? $data : [];
}

function iw_json_response(array $data, int $status = 200): void
{
    http_response_code($status);
    echo json_encode($data, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
    exit;
}

function iw_openai_request(array $payload): array
{
    if (!function_exists('curl_init')) {
        iw_json_response(['ok' => false, 'error' => 'PHP cURL is required for Intelligent Writer. Enable the cURL extension on the server.'], 500);
    }

    $apiKey = getenv('OPENAI_API_KEY') ?: ($_ENV['OPENAI_API_KEY'] ?? '');
    if (!$apiKey) {
        iw_json_response([
            'ok' => false,
            'error' => 'OPENAI_API_KEY is not configured on the server. Add it as an environment variable before using Intelligent Writer.'
        ], 503);
    }

    $ch = curl_init('https://api.openai.com/v1/chat/completions');
    if (!$ch) {
        iw_json_response(['ok' => false, 'error' => 'Could not initialize the OpenAI request.'], 500);
    }

    curl_setopt_array($ch, [
        CURLOPT_POST => true,
        CURLOPT_HTTPHEADER => [
            'Authorization: Bearer ' . $apiKey,
            'Content-Type: application/json',
        ],
        CURLOPT_POSTFIELDS => json_encode($payload, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES),
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_TIMEOUT => 150,
    ]);

    $response = curl_exec($ch);
    $errno = curl_errno($ch);
    $error = curl_error($ch);
    $status = (int) curl_getinfo($ch, CURLINFO_RESPONSE_CODE);
    curl_close($ch);

    if ($errno) {
        iw_json_response(['ok' => false, 'error' => 'OpenAI request failed: ' . $error], 502);
    }

    $data = json_decode((string) $response, true);
    if (!is_array($data)) {
        iw_json_response(['ok' => false, 'error' => 'OpenAI returned a non-JSON response.'], 502);
    }

    if ($status >= 400) {
        $message = $data['error']['message'] ?? 'OpenAI returned an error.';
        iw_json_response(['ok' => false, 'error' => $message], $status);
    }

    return $data;
}

function iw_response_schema(string $name, array $schema): array
{
    return [
        'type' => 'json_schema',
        'json_schema' => [
            'name' => $name,
            'strict' => true,
            'schema' => $schema,
        ],
    ];
}

function iw_request_structured(string $model, array $messages, string $schemaName, array $schema, float $temperature = 0.7): array
{
    $payload = [
        'model' => $model,
        'messages' => $messages,
        'temperature' => $temperature,
        'response_format' => iw_response_schema($schemaName, $schema),
    ];
    $data = iw_openai_request($payload);
    $content = $data['choices'][0]['message']['content'] ?? '';
    if (!is_string($content) || trim($content) === '') {
        iw_json_response(['ok' => false, 'error' => 'OpenAI returned an empty completion.'], 502);
    }
    $result = json_decode($content, true);
    if (!is_array($result)) {
        iw_json_response(['ok' => false, 'error' => 'OpenAI returned invalid structured output.'], 502);
    }
    return $result;
}

function iw_string_list($value): array
{
    if (!is_array($value)) {
        return [];
    }
    $items = [];
    foreach ($value as $item) {
        $text = trim((string) $item);
        if ($text !== '') {
            $items[] = $text;
        }
    }
    return array_values($items);
}

function iw_detail_string($value): string
{
    if ($value === null) {
        return '';
    }
    if (is_bool($value)) {
        return $value ? 'true' : 'false';
    }
    return trim((string) $value);
}

