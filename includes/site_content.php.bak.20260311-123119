function site_example_by_slug(?string $slug): ?array
{
    $slug = trim((string) $slug);
    if ($slug === '') {
        return null;
    }
    foreach (site_examples() as $example) {
        if (($example['slug'] ?? '') === $slug) {
            return $example;
        }
    }
    return null;
}


