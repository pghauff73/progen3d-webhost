function site_intelligent_writer_reference_text(): string
{
    $parts = [];
    $parts[] = "LIVE PARSER RULES";
    foreach (site_reference_sections() as $section) {
        $parts[] = $section['title'] . ': ' . ($section['intro'] ?? '');
        foreach (($section['items'] ?? []) as $item) {
            $parts[] = '- ' . ($item['syntax'] ?? '') . ' — ' . ($item['meaning'] ?? '');
        }
    }

    $parts[] = "DOCUMENTATION HIGHLIGHTS";
    foreach (site_docs_sections() as $section) {
        $parts[] = $section['title'] . ': ' . implode(' ', array_map('strval', $section['body'] ?? []));
        foreach (($section['bullets'] ?? []) as $bullet) {
            $parts[] = '- ' . $bullet;
        }
    }

    $parts[] = "STRUCTURAL ARCHETYPE REFERENCE";
    $archetypes = site_archetype_reference();
    foreach (($archetypes['categories'] ?? []) as $category) {
        $parts[] = ($category['title'] ?? 'Category') . ': ' . ($category['intro'] ?? '');
        foreach (($category['motifs'] ?? []) as $motif) {
            $parts[] = '* ' . ($motif['name'] ?? 'Motif') . ' — ' . ($motif['description'] ?? '');
            if (!empty($motif['parameters'])) {
                $parts[] = '  params: ' . implode(', ', array_map('strval', $motif['parameters']));
            }
            if (!empty($motif['uses'])) {
                $parts[] = '  uses: ' . implode(', ', array_map('strval', $motif['uses']));
            }
        }
    }

    $parts[] = "INTELLIGENT WRITER REFERENCE PRIORITIES";
    $parts[] = '- Prefer current live rule headers: RuleName(vars_resolve) repeat_expr -> { rule body } or RuleName(vars_resolve) repeat_expr -> pre_rules | main_bodyrules | post_rules.';
    $parts[] = '- Treat repeat_expr as something that should resolve to an integer count.';
    $parts[] = '- Use Start -> body only for the top entry rule or for very simple helper rules with no resolved variables.';
    $parts[] = '- Use conditional rule forms directly when needed: ?(cond_expr) Rule and ?(cond_expr) rulemain : rulealt.';
    $parts[] = '- Use grouped blocks [ ... ] inside rule bodies to build composable structure.';
    $parts[] = '- Use ranged variables with R name ( min max ) or R* name ( min max ) inside rule bodies only, never as standalone top-level declarations.';
    $parts[] = '- Keep math compact with no spaces once the expression begins.';

    $parts[] = "EXECUTION ADAPTATION RULES";
    $parts[] = '- The live parser is stricter than the archetype pseudocode. Use executable grammar syntax only.';
    $parts[] = '- Use only supported transforms: T ( x y z ), S ( sx sy sz ), A ( angle axis ), optional DS/DT and DSX/DSY/DSZ DTX/DTY/DTZ.';
    $parts[] = '- Use only supported instances: I ( Cube texture scale ), I ( CubeX texture scale ), I ( CubeY texture scale ), I ( CubeZ texture scale ).';
    $parts[] = '- Include a visible base/plinth under the structure.';
    $parts[] = '- Favor grouped blocks [ ... ] and readable helper rules over unsupported pseudocode operators like RotateAroundAxis or TranslateRadial.';
    $parts[] = '- Adapt archetype logic into executable rule expansions using T/S/A, current conditional syntax, current rule-header syntax, and helper rules.';
    $parts[] = '- Use cube-based geometry only unless the prompt explicitly requires a beam-like orientation, then use CubeX/CubeY/CubeZ.';
    return implode("\n", $parts);
}

