<?php
require __DIR__ . '/includes/bootstrap.php';
if (current_user()) {
    header('Location: editor.php');
    exit;
}

$errors = [];
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verify_csrf();
    $username = trim((string) ($_POST['username'] ?? ''));
    $password = (string) ($_POST['password'] ?? '');
    $confirm = (string) ($_POST['password_confirm'] ?? '');

    if ($username === '' || !preg_match('/^[A-Za-z0-9_-]{3,32}$/', $username)) {
        $errors[] = 'Choose a username with 3 to 32 letters, numbers, underscores, or dashes.';
    }
    if (strlen($password) < 8) {
        $errors[] = 'Password must be at least 8 characters.';
    }
    if ($password !== $confirm) {
        $errors[] = 'Password confirmation does not match.';
    }
    if (find_user_by_username($username)) {
        $errors[] = 'That username is already in use.';
    }

    if (!$errors) {
        $user = create_user_record($username, password_hash($password, PASSWORD_DEFAULT));
        session_regenerate_id(true);
        $_SESSION['user_id'] = (int) $user['id'];
        csrf_regenerate_token();
        flash_set('success', 'Account created. Welcome to the grammar studio.');
        header('Location: editor.php');
        exit;
    }
}

render_header('Create account', 'login');
